package test1;

import java.util.Scanner;

public class Test04 {
	public static void main(String[] args) {
		
		Scanner sc = new Scanner(System.in);
		
		System.out.print("점수입력 : ");
		int score = Integer.parseInt(sc.nextLine());
		char grade;
		
		if(score >90) {
			grade = 'A';
		} else if (score <=90){
			grade = 'B';
		} else if (score <=80) {
			grade = 'C';
		} else if (score <=70) {
			grade = 'D';
		} else {
			grade = 'F';
		}
		
		System.out.println("등급은 " + grade + "입니다.");
		
		
	}
}
