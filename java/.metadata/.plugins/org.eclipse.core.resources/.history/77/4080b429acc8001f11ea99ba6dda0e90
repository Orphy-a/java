public class ForTest {
	public static void main(String[] args) {
		
		//for
		for(int i = 1;i<=10;i++) {
			System.out.println("i : " + i);
		}
		
		//1부터 10까지 합
		
		
		//1부터 10까지 짝수합
		
		//for 중첩
		
		//구구단
		for(int i = 2;i<=9;i++) {
			for(int j = 1;j<=9;j++) {
				System.out.println(i + " * " + j + " = " + (i * j));
			}
		}
		//별삼각형
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		//삼각형 만들기 테스트
		System.out.println("삼각형 만들기 테스트");
		
		for(int i = 0;i<5;i++) {
			for(int j = 0;j<=i;j++) {
				System.out.print("*");
			}
			System.out.println();
		}
		
		
	}
	
}
