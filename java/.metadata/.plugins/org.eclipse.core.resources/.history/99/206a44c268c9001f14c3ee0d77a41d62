public class WhileTest {
	public static void main(String[] args) {
		
		//1부터 10까지 합
		
		int i = 1;
		int sum = 0;
		
		while(i<=10) {
			sum += i;
			i++;
		}
		
		System.out.println("1부터 10까지 합 : " + sum);
		
		//do-while
		int tot = 0;
		int j = 1;
	
		do {
			if(j % 2 == 0) {
				tot+=j;
				j++;
			} else {
				j++;
			}
		}while(j<=10);
		System.out.println("1부터 10까지 짝수 합 : " + tot);
		//break
		
		//continue
		
	}
}
