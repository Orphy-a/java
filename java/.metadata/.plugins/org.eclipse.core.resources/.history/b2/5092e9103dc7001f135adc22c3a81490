public class VariableTest {
	
	public static void main(String[] args) {
		
		//변수
		int a = 3;
		int b = 7;
		
		System.out.println("a : " + a);
		System.out.println("b : " + b);
		System.out.println();
		
		a = 5;
		b = 9;
		
		System.out.println("a : " + a);
		System.out.println("b : " + b);
		
		
		//상수
		
	}
}
