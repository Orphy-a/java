public class ForTest {
	public static void main(String[] args) {
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		
		//삼각형 만들기 테스트
		System.out.println("삼각형 만들기 테스트");
		
		for(int i = 0;i<5;i++) {
			for(int j = 0;j<=i;j++) {
				System.out.print("*");
			}
			System.out.println();
		}
		
		
	}
	
}
