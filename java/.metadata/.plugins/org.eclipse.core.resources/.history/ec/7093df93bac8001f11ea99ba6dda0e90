package ch04.sec03;

public class SwitchCharExample {
	public static void main(String[] args) {
		char grade = 'B';
		
		switch(grade) {
			case 'A':
			case 'a':
				System.out.println("우수사원입니다.");
				break;
			case 'B':
			case 'b':
				System.out.println("우수사원입니다.");
				break;
			case 'C':
			case 'c':
				System.out.println("우수사원입니다.");
				break;
			default:
				System.out.println();
		}
	}
}
