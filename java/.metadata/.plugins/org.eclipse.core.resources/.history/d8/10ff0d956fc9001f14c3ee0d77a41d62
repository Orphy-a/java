package test1;

import java.util.Scanner;

public class Test06 {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		
		int x = sc.nextInt();
		System.out.print("x값 : " + x);
		
		int y = sc.nextInt();
		System.out.print("y값 : " + y);
		
		
		String result = x > y ? "x가 더큽니다." : "y가 더큽니다.";
		
		System.out.println(result);
		
		sc.close();
	}
}
