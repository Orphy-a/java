package step1;

import java.util.Scanner;

public class Test01 {
	public static void main(String[] args) {
		
		Scanner sc = new Scanner(System.in);
		
		byte a = sc.nextByte();
		byte b = sc.nextByte();
		
		if(a>b) {
			System.out.println(">");
		}else if(a<b) {
			System.out.println("<");
		} else {
			System.out.println("=");
		}
		
	}
	
}
